---
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy border-t border-brand-teal-mid/40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <img
            src={`${base}${config.branding.logoLight.replace(/^\//, '')}`}
            alt={`${config.site.title} logo`}
            class="h-16 w-auto object-contain"
            width="64" height="64"
          />
          <span class="font-display font-700 text-white text-base tracking-tight">{config.site.title}</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Mayo-based expediting and brokerage. Weekend runs on the Silver Trail — we work the weekends so you don't have to.
        </p>
        <!-- Cyan rule accent -->
        <div class="w-8 h-0.5 bg-brand-cyan mt-5"></div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="label-tag mb-5">Navigation</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={base} class="text-gray-400 hover:text-brand-cyan transition-colors">Home</a></li>
          {config.features.faq && (
            <li><a href={`${base}faq/`} class="text-gray-400 hover:text-brand-cyan transition-colors">FAQ</a></li>
          )}
          <li><a href={`${base}contact/`} class="text-gray-400 hover:text-brand-cyan transition-colors">Contact</a></li>
          <li><a href={`${base}privacy/`} class="text-gray-400 hover:text-brand-cyan transition-colors">Privacy Policy</a></li>
          <li><a href={`${base}terms/`} class="text-gray-400 hover:text-brand-cyan transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="label-tag mb-5">Contact</h3>
        <div class="space-y-3 text-sm">
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-brand-cyan-dim flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-gray-400">{config.contact.address}</span>
          </div>
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-brand-cyan-dim flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${config.contact.phone}`} class="text-gray-400 hover:text-brand-cyan transition-colors font-medium">
              {config.contact.phone}
            </a>
          </div>
          {config.contact.email && (
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-brand-cyan-dim flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${config.contact.email}`} class="text-gray-400 hover:text-brand-cyan transition-colors">
                {config.contact.email}
              </a>
            </div>
          )}
          <div class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-brand-cyan-dim flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-400">{config.contact.businessHours}</span>
          </div>
        </div>

        {(config.social.facebook || config.social.instagram || config.social.linkedin) && (
          <div class="flex gap-2.5 mt-6">
            {config.social.facebook && (
              <a href={config.social.facebook} class="w-8 h-8 bg-brand-teal rounded flex items-center justify-center text-brand-cyan-dim hover:text-brand-cyan hover:bg-brand-teal-mid transition-all" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
              </a>
            )}
            {config.social.instagram && (
              <a href={config.social.instagram} class="w-8 h-8 bg-brand-teal rounded flex items-center justify-center text-brand-cyan-dim hover:text-brand-cyan hover:bg-brand-teal-mid transition-all" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            )}
            {config.social.linkedin && (
              <a href={config.social.linkedin} class="w-8 h-8 bg-brand-teal rounded flex items-center justify-center text-brand-cyan-dim hover:text-brand-cyan hover:bg-brand-teal-mid transition-all" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" clip-rule="evenodd"/></svg>
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-brand-teal-mid/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center text-xs text-gray-400">
      <p class="text-gray-400">&copy; {currentYear} {config.site.title}. All rights reserved. Mayo, Yukon.</p>
      <div class="flex gap-5 mt-2 md:mt-0">
        <a href={`${base}privacy/`} class="hover:text-brand-cyan transition-colors">Privacy</a>
        <a href={`${base}terms/`} class="hover:text-brand-cyan transition-colors">Terms</a>
        {config.features.faq && (
          <a href={`${base}faq/`} class="hover:text-brand-cyan transition-colors">FAQ</a>
        )}
      </div>
    </div>
  </div>
</footer>
