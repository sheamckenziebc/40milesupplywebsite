---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const cContactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email, availableLanguage: "English" };
cContactPt["@type"] = "ContactPoint";
const cAddr: Record<string, any> = { addressLocality: "Mayo", addressRegion: "Yukon", addressCountry: "CA" };
cAddr["@type"] = "PostalAddress";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt, address: cAddr };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);

const mapLat = config.integrations.map_coordinates.lat;
const mapLng = config.integrations.map_coordinates.lng;
const mapTitle = config.site.title;
const mapAddress = config.contact.address;
---

<BaseLayout title={`Contact | ${config.site.title}`} description={`Get in touch with 40 Mile Supply for freight quotes, pickup coordination, or questions about weekend runs between Mayo and Whitehorse.`}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Get In Touch</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
        Request a <span class="text-amber-400">Freight Quote</span>
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        Need freight moved between Mayo and Whitehorse? Get in touch for a quote, pickup coordination, or to ask about upcoming weekend runs. We'll respond with clear next steps and realistic timing.
      </p>
    </div>
  </section>

  <!-- Contact Form & Info Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Send a Quote Request</h2>
          <p class="text-gray-500 mb-8">Fill out the form and we'll get back to you with next steps.</p>

          <form
            action={`https://formspree.io/f/${config.integrations.formspree_id}`}
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                placeholder="Your name"
                autocomplete="name"
              />
            </div>

            <div>
              <label for="business" class="block text-sm font-medium text-gray-700 mb-2">Business / Organization</label>
              <input
                type="text"
                id="business"
                name="business"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                placeholder="Company or organization (optional)"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                  placeholder="Phone"
                  autocomplete="tel"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                  placeholder="Email"
                  autocomplete="email"
                />
              </div>
            </div>

            <div>
              <label for="freight-type" class="block text-sm font-medium text-gray-700 mb-2">Freight Type</label>
              <select
                id="freight-type"
                name="freight-type"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
              >
                <option value="">Select type...</option>
                <option value="weekend-freight-run">Weekend Freight Run</option>
                <option value="whitehorse-pickup">Whitehorse Pickup</option>
                <option value="business-restock">Business Restock</option>
                <option value="contractor-project">Contractor / Project Freight</option>
                <option value="custom">Custom Request</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="pickup" class="block text-sm font-medium text-gray-700 mb-2">Pickup Location</label>
                <input
                  type="text"
                  id="pickup"
                  name="pickup"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                  placeholder="e.g. Whitehorse, Mayo"
                />
              </div>
              <div>
                <label for="delivery" class="block text-sm font-medium text-gray-700 mb-2">Delivery Location</label>
                <input
                  type="text"
                  id="delivery"
                  name="delivery"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                  placeholder="e.g. Mayo, Whitehorse"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-2">What needs to be moved? *</label>
              <textarea
                id="message"
                name="message"
                rows="3"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                placeholder="Describe your freight and any special requirements"
              ></textarea>
            </div>

            <div>
              <label for="timing" class="block text-sm font-medium text-gray-700 mb-2">Preferred timing</label>
              <input
                type="text"
                id="timing"
                name="timing"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                placeholder="e.g. Next weekend, recurring monthly"
              />
            </div>

            <div>
              <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">Additional notes</label>
              <textarea
                id="notes"
                name="notes"
                rows="2"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:border-[#1F4A46] transition-colors"
                placeholder="Any other details we should know"
              ></textarea>
            </div>

            <input type="text" name="_gotcha" style="display:none" />

            <button
              type="submit"
              class="w-full bg-[#1F4A46] text-white py-3.5 px-6 rounded-lg font-semibold text-lg hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#1F4A46] focus:ring-offset-2 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              Send Quote Request
            </button>
            <p class="text-xs text-gray-400 text-center mt-2">We'll respond as soon as we can. No obligation.</p>
          </form>

          <div id="form-status" class="mt-4 p-4 rounded-md hidden" aria-live="polite" role="status">
            <p id="form-message"></p>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-gray-900 mb-2">Contact 40 Mile Supply</h2>
          <p class="text-gray-500 mb-8">Quote requests and questions by phone or email.</p>

          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-[#1F4A46]/10 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-[#1F4A46]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Address</h3>
                <p class="text-gray-600">{config.contact.address}</p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-[#1F4A46]/10 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-[#1F4A46]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Phone</h3>
                <a href={`tel:${config.contact.phone}`} class="text-[#1F4A46] hover:underline transition-colors">
                  {config.contact.phone}
                </a>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-[#1F4A46]/10 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-[#1F4A46]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Email</h3>
                <a href={`mailto:${config.contact.email}`} class="text-[#1F4A46] hover:underline transition-colors">
                  {config.contact.email}
                </a>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-[#1F4A46]/10 rounded-lg flex items-center justify-center">
                  <svg class="w-6 h-6 text-[#1F4A46]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Business Hours</h3>
                <p class="text-gray-600">{config.contact.businessHours}</p>
              </div>
            </div>
          </div>

          <div class="mt-8 p-4 bg-gray-50 rounded-lg">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Response time</h3>
            <p class="text-gray-600">
              We respond to quote requests and questions as quickly as we can. For urgent freight needs, please call.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Find Us</h2>
        <p class="text-xl text-gray-600">Mayo, Yukon — serving the Mayo–Whitehorse route</p>
      </div>
      <div class="bg-white rounded-lg shadow-sm overflow-hidden">
        <div id="map" class="h-96 w-full bg-gray-200 flex items-center justify-center">
          <div class="text-center">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-gray-500">Interactive Map</p>
            <p class="text-sm text-gray-400 mt-2">{config.contact.address}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={contactJsonLd} />
  <div id="map-data" data-lat={mapLat} data-lng={mapLng} data-title={mapTitle} data-address={mapAddress} style="display:none;"></div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status');
    const formMessage = document.getElementById('form-message');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Sending...';
        }

        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });

          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded-md bg-green-50 border border-green-200';
            formMessage!.textContent = 'Thanks for your message. We\'ll get back to you with next steps.';
            formMessage!.className = 'text-green-800 font-medium';
            form.reset();
          } else {
            throw new Error('Form submission failed');
          }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded-md bg-red-50 border border-red-200';
          formMessage!.textContent = 'Something went wrong. Please try again or call us.';
          formMessage!.className = 'text-red-800 font-medium';
        }

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Quote Request';
        }
        formStatus!.classList.remove('hidden');
      });
    }

    const mapContainer = document.getElementById('map');
    if (mapContainer) {
      const mapObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            mapObserver.unobserve(entry.target);
            const link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(link);
            const script = document.createElement('script');
            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            script.onload = () => {
              const mapData = document.getElementById('map-data');
              if (!mapData) return;
              const lat = parseFloat(mapData.dataset.lat || '0');
              const lng = parseFloat(mapData.dataset.lng || '0');
              const title = mapData.dataset.title || '';
              const address = mapData.dataset.address || '';
              const map = (window as any).L.map('map').setView([lat, lng], 15);
              (window as any).L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
              }).addTo(map);
              (window as any).L.marker([lat, lng]).addTo(map)
                .bindPopup('<b>' + title + '</b><br>' + address)
                .openPopup();
            };
            document.body.appendChild(script);
          }
        });
      }, { rootMargin: '200px' });
      mapObserver.observe(mapContainer);
    }
  </script>

  <Footer slot="footer" />
</BaseLayout>
