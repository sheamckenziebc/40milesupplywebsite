---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const cContactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", availableLanguage: "English" };
if (config.contact.email) cContactPt.email = config.contact.email;
cContactPt["@type"] = "ContactPoint";
const cAddr: Record<string, any> = { addressLocality: "Mayo", addressRegion: "Yukon", addressCountry: "CA" };
cAddr["@type"] = "PostalAddress";
const cMainEntity: Record<string, any> = { name: config.site.title, contactPoint: cContactPt, address: cAddr };
cMainEntity["@type"] = "Organization";
const contactObj: Record<string, any> = { mainEntity: cMainEntity };
contactObj["@context"] = "https://schema.org";
contactObj["@type"] = "ContactPage";
const contactJsonLd = JSON.stringify(contactObj);
---

<BaseLayout
  title={`Contact | ${config.site.title}`}
  description="Get in touch with 40 Mile Supply for freight quotes, pickup coordination, or questions about weekend runs between Mayo and Whitehorse."
>
  <Header slot="header" />

  <!-- Page header band -->
  <div class="bg-brand-navy border-b border-brand-teal-mid/50 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="cyan-rule"></span>
      <h1 class="font-display font-700 text-3xl md:text-4xl text-white mb-2">Request a Freight Quote</h1>
      <p class="text-gray-400">Tell us what you need to move and we'll respond with clear next steps.</p>
    </div>
  </div>

  <section class="py-14 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Form (3/5) -->
        <div class="lg:col-span-3 animate-on-scroll">
          <form
            action={`https://formspree.io/f/${config.integrations.formspree_id}`}
            method="POST"
            class="space-y-4"
            id="contact-form"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Name *</label>
                <input
                  type="text" id="name" name="name" required
                  autocomplete="name" placeholder="Your name"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
              <div>
                <label for="business" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Business / Org</label>
                <input
                  type="text" id="business" name="business"
                  placeholder="Optional"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="phone" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Phone *</label>
                <input
                  type="tel" id="phone" name="phone" required
                  autocomplete="tel" placeholder="Phone number"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Email *</label>
                <input
                  type="email" id="email" name="email" required
                  autocomplete="email" placeholder="Email address"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="freight-type" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Freight Type</label>
              <select
                id="freight-type" name="freight-type"
                class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
              >
                <option value="">Select type...</option>
                <option value="weekend-freight-run">Weekend Freight Run</option>
                <option value="whitehorse-pickup">Whitehorse Pickup</option>
                <option value="business-restock">Business Restock</option>
                <option value="contractor-project">Contractor / Project Freight</option>
                <option value="custom">Custom Request</option>
              </select>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="pickup" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Pickup Location</label>
                <input
                  type="text" id="pickup" name="pickup"
                  placeholder="e.g. Whitehorse"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
              <div>
                <label for="delivery" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Delivery Location</label>
                <input
                  type="text" id="delivery" name="delivery"
                  placeholder="e.g. Mayo"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">What needs to be moved? *</label>
              <textarea
                id="message" name="message" rows="4" required
                placeholder="Describe your freight, quantity, and preferred timing"
                class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-cyan/30 focus:border-brand-cyan transition-colors resize-none"
              ></textarea>
            </div>

            <input type="text" name="_gotcha" style="display:none" />

            <button
              type="submit"
              class="w-full bg-brand-orange text-white py-3.5 px-6 rounded font-semibold text-base hover:bg-brand-orange-dk focus:outline-none focus:ring-2 focus:ring-brand-cyan/40 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send Quote Request
            </button>
            <p class="text-xs text-gray-400 text-center">We'll respond as soon as we can. No obligation.</p>
          </form>

          <div id="form-status" class="mt-4 p-4 rounded hidden" aria-live="polite" role="status">
            <p id="form-message"></p>
          </div>
        </div>

        <!-- Contact info (2/5) -->
        <div class="lg:col-span-2 animate-on-scroll">
          <div class="bg-brand-navy border border-brand-teal-mid rounded-md p-7 h-full">
            <h2 class="font-display font-700 text-white text-lg mb-6">Contact Details</h2>

            <div class="space-y-5">
              {[
                {
                  icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
                  label: "Based in",
                  value: config.contact.address,
                  href: null,
                },
                {
                  icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
                  label: "Phone",
                  value: config.contact.phone,
                  href: `tel:${config.contact.phone}`,
                },
                ...(config.contact.email ? [{
                  icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
                  label: "Email",
                  value: config.contact.email,
                  href: `mailto:${config.contact.email}`,
                }] : []),
                {
                  icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
                  label: "Hours",
                  value: config.contact.businessHours,
                  href: null,
                },
              ].map(item => (
                <div class="flex items-start gap-4">
                  <div class="w-9 h-9 bg-brand-teal rounded flex items-center justify-center flex-shrink-0 mt-0.5">
                    <svg class="w-4 h-4 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-0.5">{item.label}</div>
                    {item.href ? (
                      <a href={item.href} class="text-brand-cyan hover:text-white text-sm transition-colors font-medium">{item.value}</a>
                    ) : (
                      <div class="text-gray-300 text-sm">{item.value}</div>
                    )}
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8 pt-6 border-t border-brand-teal-mid/50">
              <p class="text-gray-400 text-xs leading-relaxed">For urgent freight needs, please call. We respond to quote requests as quickly as possible.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={contactJsonLd} />

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formStatus = document.getElementById('form-status');
    const formMessage = document.getElementById('form-message');
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>Sending...';
        }
        const formData = new FormData(form);
        try {
          const response = await fetch(form.action, { method: 'POST', body: formData, headers: { 'Accept': 'application/json' } });
          if (response.ok) {
            formStatus!.className = 'mt-4 p-4 rounded bg-green-950 border border-green-800';
            formMessage!.textContent = "Thanks — we'll get back to you with next steps.";
            formMessage!.className = 'text-green-300 text-sm font-medium';
            form.reset();
          } else { throw new Error(); }
        } catch {
          formStatus!.className = 'mt-4 p-4 rounded bg-red-950 border border-red-800';
          formMessage!.textContent = 'Something went wrong. Please try again or call us.';
          formMessage!.className = 'text-red-300 text-sm font-medium';
        }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Quote Request'; }
        formStatus!.classList.remove('hidden');
      });
    }
  </script>

  <Footer slot="footer" />
</BaseLayout>
