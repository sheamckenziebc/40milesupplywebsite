---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const aboutLogoUrl = new URL(config.branding.logo, Astro.site).href;
const contactPt: Record<string, any> = { telephone: config.contact.phone, contactType: "Customer Service", email: config.contact.email };
contactPt["@type"] = "ContactPoint";
const addr: Record<string, any> = { addressLocality: "Mayo", addressRegion: "Yukon", addressCountry: "CA" };
addr["@type"] = "PostalAddress";
const mainEntity: Record<string, any> = { name: config.site.title, description: config.site.description, url: config.site.url, logo: aboutLogoUrl, contactPoint: contactPt, address: addr };
mainEntity["@type"] = "Organization";
const aboutObj: Record<string, any> = { mainEntity };
aboutObj["@context"] = "https://schema.org";
aboutObj["@type"] = "AboutPage";
const aboutJsonLd = JSON.stringify(aboutObj);
---

<BaseLayout title={`About | ${config.site.title}`} description={`Learn about 40 Mile Supply — a Mayo-based freight service offering dependable weekend runs between Mayo and Whitehorse.`}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">Our Story</span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
          Built for the Mayo–Whitehorse Route
        </h1>
        <p class="text-xl text-blue-100 leading-relaxed">
          A practical local freight company focused on doing one route well: dependable weekend freight between Mayo and Whitehorse.
        </p>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Company Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Why We Started
          </h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            40 Mile Supply was created to solve a practical problem: getting freight between Mayo and Whitehorse on a dependable schedule. In the North, timing matters. A missed part, delayed order, or late supplier pickup can affect stores, projects, maintenance work, and day-to-day operations.
          </p>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">
            We are not a national courier, an e-commerce shop, or a moving company. We are a route-focused local freight service — weekend runs, Whitehorse pickups, and practical delivery support for businesses, contractors, organizations, and local customers.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            Clear communication and straightforward coordination are at the centre of what we do. You tell us what needs to move; we work with you on timing and details.
          </p>
        </div>
        <div class="relative">
          <img
            src={`${base}assets/about-story.svg`}
            alt="40 Mile Supply — Mayo to Whitehorse freight"
            class="rounded-2xl shadow-lg w-full h-96 object-cover"
            loading="lazy"
          />
          <!-- Non-fabricated signal cards -->
          <div class="absolute -bottom-8 left-8 right-8 bg-white rounded-xl shadow-xl p-6 grid grid-cols-2 gap-4 text-center">
            <div>
              <div class="text-xl font-extrabold text-[#1F4A46]">Mayo, Yukon</div>
              <div class="text-sm text-gray-500 font-medium">Based Here</div>
            </div>
            <div>
              <div class="text-xl font-extrabold text-[#1F4A46]">Weekend Route</div>
              <div class="text-sm text-gray-500 font-medium">Scheduled Service</div>
            </div>
            <div>
              <div class="text-xl font-extrabold text-[#1F4A46]">Whitehorse Link</div>
              <div class="text-sm text-gray-500 font-medium">Supply Connection</div>
            </div>
            <div>
              <div class="text-xl font-extrabold text-[#1F4A46]">Built for Growth</div>
              <div class="text-sm text-gray-500 font-medium">Expanding With You</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[#1F4A46] font-semibold text-sm uppercase tracking-wider">What We Stand For</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">
          Our Values
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Principles that guide how we run freight and work with customers.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Dependability First</h3>
          <p class="text-gray-600 leading-relaxed">
            We set clear expectations and follow through. When we say we're running, we run. Communication is straightforward so you can plan.
          </p>
        </div>

        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-[#1F4A46]/10 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-[#1F4A46]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Local Knowledge Matters</h3>
          <p class="text-gray-600 leading-relaxed">
            We know the Mayo–Whitehorse corridor. That knowledge shapes how we schedule, coordinate pickups, and handle the details that matter on this route.
          </p>
        </div>

        <div class="animate-on-scroll card-hover bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
          <div class="card-icon w-14 h-14 bg-green-100 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Straightforward Service</h3>
          <p class="text-gray-600 leading-relaxed">
            No corporate jargon, no overpromising. We tell you what we can do, how it works, and what to expect. Quote-based freight coordination, plain and simple.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <span class="text-[#1F4A46] font-semibold text-sm uppercase tracking-wider">Where We Operate</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2">
          Mayo, Whitehorse & the Silver Trail
        </h2>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">We focus on the Mayo–Whitehorse route and the Silver Trail corridor. Need something outside this area? <a href={`${base}contact/`} class="text-[#1F4A46] hover:underline">Contact us</a> — we may still be able to help.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 animate-on-scroll">
        <div class="flex items-center gap-2 bg-gray-50 rounded-xl px-4 py-3 border border-gray-200">
          <svg class="w-4 h-4 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="text-sm font-medium text-gray-700">Mayo, Yukon</span>
        </div>
        <div class="flex items-center gap-2 bg-gray-50 rounded-xl px-4 py-3 border border-gray-200">
          <svg class="w-4 h-4 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="text-sm font-medium text-gray-700">Whitehorse, Yukon</span>
        </div>
        <div class="flex items-center gap-2 bg-gray-50 rounded-xl px-4 py-3 border border-gray-200">
          <svg class="w-4 h-4 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.45-2.72A2 2 0 013 15.73V4a2 2 0 012-2h14a2 2 0 012 2v11.73a2 2 0 01-1.55 1.92L15 20"/></svg>
          <span class="text-sm font-medium text-gray-700">Silver Trail corridor</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="relative py-20 bg-gradient-to-br from-[#1F4A46] to-slate-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to move freight?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Get in touch for a quote or to ask about upcoming weekend runs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
        >
          Request a Quote
        </a>
        <a
          href={`tel:${config.contact.phone}`}
          class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Call Us
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={aboutJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
