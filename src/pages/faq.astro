---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const faqs = [
  {
    question: "Do you only run freight on weekends?",
    answer: "Our main service is weekend freight runs between Mayo and Whitehorse. That schedule helps businesses and projects plan restocks and pickups. If you have a different timing need, contact us — we may be able to accommodate or suggest alternatives."
  },
  {
    question: "What kinds of freight do you handle?",
    answer: "We handle general commercial freight: supplies, store orders, contractor materials, tools, and operational goods for businesses, organizations, and local customers on the Mayo–Whitehorse route. We do not offer same-day courier or full-service moving. If you're unsure whether your shipment fits, ask before booking."
  },
  {
    question: "Do you pick up from Whitehorse suppliers and stores?",
    answer: "Yes. We offer Whitehorse supplier pickups — collecting from stores, suppliers, or service providers in Whitehorse and coordinating delivery back to Mayo on our scheduled runs. Details and pricing are quote-based."
  },
  {
    question: "How do I get a quote?",
    answer: "Use our contact form or call/email. Tell us what you need to move, pickup and delivery locations, and preferred timing. We'll respond with next steps and a quote. No obligation."
  },
  {
    question: "Do you offer recurring service?",
    answer: "Yes. We can coordinate recurring runs for business restock, project freight, or other regular needs. Contact us to discuss schedule and pricing."
  },
  {
    question: "Do you transport dangerous goods or restricted items?",
    answer: "Not at launch unless explicitly approved and handled in full compliance with applicable regulations. If you are unsure whether your shipment falls into this category, ask before booking."
  },
  {
    question: "Where are you based?",
    answer: "We are based in Mayo, Yukon, and focus on the Mayo–Whitehorse route and the Silver Trail corridor."
  }
];

const faqItems = faqs.map(f => {
  const item: Record<string, any> = { name: f.question, acceptedAnswer: { text: f.answer } };
  item["@type"] = "Question";
  item.acceptedAnswer["@type"] = "Answer";
  return item;
});
const faqObj: Record<string, any> = { mainEntity: faqItems };
faqObj["@context"] = "https://schema.org";
faqObj["@type"] = "FAQPage";
const faqJsonLd = JSON.stringify(faqObj);
---

<BaseLayout title={`FAQ | ${config.site.title}`} description="Frequently asked questions about 40 Mile Supply freight services, weekend runs, Whitehorse pickups, quotes, and the Mayo–Whitehorse route.">
  <Header slot="header" />

  <!-- Page header band -->
  <div class="bg-brand-navy border-b border-brand-teal-mid/50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="cyan-rule"></span>
      <h1 class="font-display font-700 text-3xl md:text-4xl text-white mb-2">Frequently Asked Questions</h1>
      <p class="text-gray-400">Straight answers about our freight services and the Mayo–Whitehorse route.</p>
    </div>
  </div>

  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-2 stagger-children" id="faq-list">
        {faqs.map((faq, index) => (
          <details
            class="animate-on-scroll group border border-gray-200 rounded-md overflow-hidden hover:border-brand-cyan/30 transition-colors"
            open={index === 0}
          >
            <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-display font-600 text-gray-900 hover:text-brand-teal transition-colors list-none [&::-webkit-details-marker]:hidden select-none">
              <span class="pr-4 text-base">{faq.question}</span>
              <svg
                class="w-4 h-4 text-brand-cyan flex-shrink-0 group-open:rotate-180 transition-transform duration-200"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-1 text-gray-600 text-sm leading-relaxed border-t border-gray-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

      <div class="mt-14 pt-10 border-t border-gray-100 animate-on-scroll">
        <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:justify-between">
          <div>
            <h2 class="font-display font-700 text-xl text-gray-900 mb-1">Still have questions?</h2>
            <p class="text-gray-500 text-sm">Reach out by phone or message — we'll get back to you.</p>
          </div>
          <div class="flex gap-3 flex-shrink-0">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center bg-brand-orange text-white px-5 py-2.5 rounded font-semibold text-sm hover:bg-brand-orange-dk transition-colors"
            >
              Contact Us
            </a>
            <a
              href={`tel:${config.contact.phone}`}
              class="inline-flex items-center justify-center border border-gray-300 text-gray-700 px-5 py-2.5 rounded font-medium text-sm hover:border-brand-cyan/40 transition-colors"
            >
              <svg class="w-4 h-4 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={faqJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
