---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;

const faqs = [
  {
    question: "What is expediting, and how is it different from hot shot?",
    answer: "In the Yukon, expediting is the standing supply run — scheduled, reliable, and built for repeat freight. We run the Mayo–Whitehorse and Dawson City–Mayo corridors on weekends at discounted weekend rates. Mine supply runs, camp resupply, contractor materials, store orders — if it moves regularly, expediting is the right service. Hot shot is the emergency. When a project is held up and a part is needed now, outside the regular schedule — that's hot shot. Priority dispatch, premium rate, no waiting for the weekend."
  },
  {
    question: "When do you run? Do you run weekdays?",
    answer: "Our scheduled expediting runs are on weekends — we work the weekends so you don't have to. Discounted weekend rates apply to scheduled runs. Weekday service is available by special arrangement. Hot shot calls can be fielded any time depending on availability — contact us directly for urgent requests."
  },
  {
    question: "What is Equipment & Material Brokerage?",
    answer: "We source and coordinate equipment and materials from suppliers across Western Canada — Whitehorse, Vancouver, Edmonton, Calgary, Grande Prairie, and wherever the right supplier happens to be. We handle vendor communication, pickup coordination, and delivery to Mayo. Automated listing monitoring, a trusted vendor network, and independent inspections before purchase decisions. You don't need to make the trip or track down suppliers yourself."
  },
  {
    question: "Do you sub-contract to other expediters?",
    answer: "Yes. If you're an expediting company that needs weekend coverage on the Silver Trail corridor, we're available to sub-contract. We're on the road anyway — reach out and we can work out an arrangement."
  },
  {
    question: "What kinds of freight do you handle?",
    answer: "We handle general commercial freight: mine and camp supplies, store orders, contractor materials, tools, equipment, and operational goods for businesses, organizations, and local customers. If you're unsure whether your shipment fits, ask before booking."
  },
  {
    question: "How do I get a quote?",
    answer: "Use our contact form or call us. Tell us what you need — freight to move, equipment to source, or an urgent hot shot request. Include pickup and delivery locations and preferred timing. We'll respond with next steps and a quote. No obligation."
  },
  {
    question: "Where are you based, and what routes do you cover?",
    answer: "We are based in Mayo, Yukon — on the Silver Trail. Our expediting and hot shot routes cover Mayo–Whitehorse and Dawson City–Mayo, with custom routes available for the right freight. Our brokerage sourcing network reaches across Western Canada — Vancouver, Edmonton, Calgary, Grande Prairie, and beyond — to get you what you need regardless of where it comes from."
  },
  {
    question: "Do you offer recurring service?",
    answer: "Yes. Mine supply runs, camp resupply, and standing freight arrangements are a core part of what expediting means. Contact us to discuss a regular schedule and pricing."
  }
];

const faqItems = faqs.map(f => {
  const item: Record<string, any> = { name: f.question, acceptedAnswer: { text: f.answer } };
  item["@type"] = "Question";
  item.acceptedAnswer["@type"] = "Answer";
  return item;
});
const faqObj: Record<string, any> = { mainEntity: faqItems };
faqObj["@context"] = "https://schema.org";
faqObj["@type"] = "FAQPage";
const faqJsonLd = JSON.stringify(faqObj);
---

<BaseLayout title={`FAQ | ${config.site.title}`} description="Frequently asked questions about 40 Mile Supply expediting services, weekend runs, hot shot dispatch, sub-contracting, and brokerage on the Silver Trail — Mayo, Yukon.">
  <Header slot="header" />

  <!-- Page header band -->
  <div class="bg-brand-navy border-b border-brand-teal-mid/50 py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="cyan-rule"></span>
      <h1 class="font-display font-700 text-3xl md:text-4xl text-white mb-2">Frequently Asked Questions</h1>
      <p class="text-gray-400">Straight answers about expediting, hot shot, brokerage, and the Silver Trail.</p>
    </div>
  </div>

  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-2 stagger-children" id="faq-list">
        {faqs.map((faq, index) => (
          <details
            class="animate-on-scroll group border border-gray-200 rounded-md overflow-hidden hover:border-brand-cyan/30 transition-colors"
            open={index === 0}
          >
            <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-left font-display font-600 text-gray-900 hover:text-brand-teal transition-colors list-none [&::-webkit-details-marker]:hidden select-none">
              <span class="pr-4 text-base">{faq.question}</span>
              <svg
                class="w-4 h-4 text-brand-teal flex-shrink-0 group-open:rotate-180 transition-transform duration-200"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-1 text-gray-600 text-sm leading-relaxed border-t border-gray-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

      <div class="mt-14 pt-10 border-t border-gray-100 animate-on-scroll">
        <div class="flex flex-col sm:flex-row sm:items-center gap-6 sm:justify-between">
          <div>
            <h2 class="font-display font-700 text-xl text-gray-900 mb-1">Still have questions?</h2>
            <p class="text-gray-500 text-sm">Reach out by phone or message — we'll get back to you.</p>
          </div>
          <div class="flex gap-3 flex-shrink-0">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center bg-brand-orange text-white px-5 py-2.5 rounded font-semibold text-sm hover:bg-brand-orange-dk transition-colors"
            >
              Contact Us
            </a>
            <a
              href={`tel:${config.contact.phone}`}
              class="inline-flex items-center justify-center border border-gray-300 text-gray-700 px-5 py-2.5 rounded font-medium text-sm hover:border-brand-cyan/40 transition-colors"
            >
              <svg class="w-4 h-4 mr-2 text-brand-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              Call
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={faqJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
