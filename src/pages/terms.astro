---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`Terms of Service | ${config.site.title}`} description={`Terms of service for ${config.site.title}. Read our terms and conditions for using our website and services.`}>
  <Header slot="header" />

  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Terms of Service</h1>
      <p class="text-gray-500 mb-12">Last updated: March 2026</p>

      <div class="prose prose-lg prose-gray max-w-none">
        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Acceptance of Terms</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          By accessing and using the {config.site.title} website, you accept and agree to be bound by these terms of service. If you do not agree to these terms, please do not use our website.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Services</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          {config.site.title} provides freight and delivery coordination services on the Mayo–Whitehorse route. Freight quotes provided through this website are subject to shipment details and confirmation. Final arrangements, pricing, and terms are confirmed separately. Availability depends on scheduling and route capacity. Some goods may be declined; we will communicate clearly if that applies.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Quotes & Arrangements</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Quotes provided through this website or by phone/email are indicative and subject to the specifics of your shipment. Final pricing and terms are confirmed before a run is booked. All arrangements are subject to our capacity and schedule.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Website Content</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          The content on this website is for general informational purposes only. While we strive to keep information accurate and up-to-date, we make no warranties about the completeness, reliability, or accuracy of this information. Service descriptions and examples may not reflect your specific shipment or situation.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Intellectual Property</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          All content on this website, including text, images, logos, and design elements, is the property of {config.site.title} and is protected by applicable copyright and trademark laws. You may not reproduce, distribute, or create derivative works from this content without our written permission.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Limitation of Liability</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          {config.site.title} shall not be liable for any indirect, incidental, special, or consequential damages arising from your use of this website. Our total liability for any claim related to this website shall not exceed the amount you paid for services through this site, if any.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Third-Party Links</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Our website may contain links to third-party websites. We are not responsible for the content, privacy policies, or practices of these external sites. Accessing third-party links is at your own risk.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Governing Law</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          These terms shall be governed by and construed in accordance with the laws of Yukon and the laws of Canada applicable therein. Any disputes arising from these terms shall be resolved in the courts of the Yukon.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Changes to Terms</h2>
        <p class="text-gray-600 mb-6 leading-relaxed">
          We reserve the right to modify these terms at any time. Changes will be posted on this page with an updated revision date. Your continued use of the website after changes are posted constitutes acceptance of the modified terms.
        </p>

        <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">Contact Us</h2>
        <p class="text-gray-600 leading-relaxed">
          If you have questions about these terms, please contact us at:<br />
          <strong>{config.site.title}</strong><br />
          {config.contact.address}<br />
          <a href={`mailto:${config.contact.email}`} class="text-[#1F4A46] hover:underline">{config.contact.email}</a><br />
          <a href={`tel:${config.contact.phone}`} class="text-[#1F4A46] hover:underline">{config.contact.phone}</a>
        </p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
