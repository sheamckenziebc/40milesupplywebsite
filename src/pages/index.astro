---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const productsPath = join(process.cwd(), 'src/data/products.yaml');
const products = yaml.load(readFileSync(productsPath, 'utf8')) as Array<{
  id: string; name: string; description: string; price: string; features: string[];
}>;
const base = import.meta.env.BASE_URL;

// Icon paths — one per service
const serviceIcons = [
  // Route/truck
  "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0",
  // Shopping bag / pickup
  "M3 3h2l.4 2M7 13h10l4-4H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z",
  // Building/store
  "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  // Hard hat / contractor
  "M9 3v2m6-2v2M9 19H7a2 2 0 01-2-2V9a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2m-4 0h4m-4 0v-4m4 0v4m-4 0H9",
  // Custom / custom request
  "M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z",
];
---

<BaseLayout title={config.site.title} description={config.site.description}>
  <Header slot="header" />

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="relative bg-brand-navy overflow-hidden py-28 md:py-36">
    <!-- Aurora blobs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-brand-cyan/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[350px] h-[350px] bg-brand-teal/40 rounded-full blur-3xl"></div>
      <div class="absolute top-1/3 right-1/3 w-[250px] h-[250px] bg-brand-orange/6 rounded-full blur-3xl"></div>
      <!-- Subtle grid overlay -->
      <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(var(--cyan) 1px, transparent 1px), linear-gradient(90deg, var(--cyan) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Label -->
      <div class="flex items-center gap-3 mb-7">
        <span class="block w-8 h-px bg-brand-cyan"></span>
        <span class="label-tag">Mayo-based freight — Yukon</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-800 text-white mb-6 leading-none tracking-tight max-w-3xl">
        Dependable Weekend Freight<br/>
        <span style="color: var(--cyan);">Mayo ↔ Whitehorse</span>
      </h1>

      <p class="text-lg text-gray-400 mb-10 max-w-xl leading-relaxed">
        Weekend freight runs, Whitehorse supplier pickups, and practical delivery coordination for businesses, contractors, and local customers on the Silver Trail.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-brand-orange text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-brand-orange-dk transition-colors"
        >
          Request a Quote
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href={`${base}faq/`}
          class="inline-flex items-center justify-center border border-brand-teal-mid text-gray-300 px-7 py-3.5 rounded font-medium text-base hover:border-brand-cyan/40 hover:text-white transition-colors"
        >
          Common Questions
        </a>
      </div>

      <!-- Route stats bar -->
      <div class="mt-14 pt-10 border-t border-brand-teal-mid/50 grid grid-cols-2 sm:grid-cols-4 gap-6">
        {[
          { value: "Mayo", label: "Based Here" },
          { value: "Whitehorse", label: "Supply Hub" },
          { value: "Weekend", label: "Scheduled Runs" },
          { value: "~400 km", label: "Route Length" },
        ].map(stat => (
          <div>
            <div class="font-display font-700 text-white text-lg">{stat.value}</div>
            <div class="text-xs text-gray-500 uppercase tracking-wider mt-0.5">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Thin cyan rule separator -->
  <div class="h-px bg-gradient-to-r from-transparent via-brand-cyan/40 to-transparent"></div>

  <!-- ── Services ─────────────────────────────────────── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 animate-on-scroll">
        <span class="cyan-rule"></span>
        <h2 class="text-3xl md:text-4xl font-display font-700 text-gray-900 mb-3">What We Move</h2>
        <p class="text-gray-500 max-w-xl">
          One route, done well. Practical freight coordination for the Mayo–Whitehorse corridor.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
        {products.map((service, i) => (
          <div class="animate-on-scroll card-hover group bg-brand-navy border border-brand-teal-mid rounded-md p-7 flex flex-col">
            <!-- Top accent bar -->
            <div class="w-full h-0.5 bg-gradient-to-r from-brand-cyan/60 to-transparent mb-6 -mt-7 -mx-7 w-[calc(100%+3.5rem)]" style="margin-top:-1.75rem; margin-left:-1.75rem; width:calc(100% + 3.5rem);"></div>

            <div class="card-icon w-11 h-11 bg-brand-teal rounded flex items-center justify-center mb-5 flex-shrink-0">
              <svg class="w-5 h-5 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={serviceIcons[i % serviceIcons.length]} />
              </svg>
            </div>

            <h3 class="font-display font-700 text-white text-lg mb-2">{service.name}</h3>
            <p class="text-gray-400 text-sm leading-relaxed flex-1">{service.description}</p>

            <a
              href={`${base}contact/`}
              class="mt-5 inline-flex items-center text-xs font-semibold text-brand-cyan hover:text-white transition-colors uppercase tracking-wider"
            >
              Request Quote
              <svg class="w-3.5 h-3.5 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Thin separator -->
  <div class="h-px bg-gradient-to-r from-transparent via-brand-cyan/20 to-transparent"></div>

  <!-- ── How It Works ──────────────────────────────────── -->
  <section class="py-20 bg-brand-navy relative overflow-hidden">
    <!-- Subtle aurora background -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute bottom-0 left-1/3 w-96 h-64 bg-brand-teal/20 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14 animate-on-scroll">
        <span class="cyan-rule"></span>
        <h2 class="text-3xl md:text-4xl font-display font-700 text-white mb-3">How It Works</h2>
        <p class="text-gray-400 max-w-md">Simple process, clear communication — quote to delivery.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 stagger-children">
        {[
          { n: "01", title: "Request a Quote", body: "Tell us what you need to move, when, and where. We respond with clear next steps." },
          { n: "02", title: "Confirm Details", body: "We confirm pickup, contact, and any instructions so the run goes smoothly." },
          { n: "03", title: "Weekend Run", body: "Freight moves on our scheduled weekend route between Mayo and Whitehorse." },
          { n: "04", title: "Delivery", body: "Delivered to your chosen location. Straightforward and done." },
        ].map((step, i) => (
          <div class="animate-on-scroll relative">
            <!-- Connector line (not last) -->
            {i < 3 && (
              <div class="hidden md:block absolute top-5 left-[3.5rem] right-0 h-px bg-brand-teal-mid"></div>
            )}
            <div class="relative flex flex-col">
              <div class="w-10 h-10 rounded border border-brand-cyan/30 bg-brand-teal flex items-center justify-center mb-5">
                <span class="font-display font-700 text-brand-cyan text-sm">{step.n}</span>
              </div>
              <h3 class="font-display font-600 text-white text-base mb-2">{step.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────── -->
  <section class="py-20 bg-brand-teal relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute right-0 top-0 w-64 h-64 bg-brand-cyan/10 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
        <div>
          <span class="label-tag mb-3 block">Ready to move freight?</span>
          <h2 class="text-3xl md:text-4xl font-display font-700 text-white leading-tight">
            Mayo to Whitehorse,<br/>on a schedule you can plan around.
          </h2>
        </div>
        <div class="flex flex-col sm:flex-row lg:flex-col gap-3 flex-shrink-0">
          <a
            href={`${base}contact/`}
            class="inline-flex items-center justify-center bg-brand-orange text-white px-7 py-3.5 rounded font-semibold hover:bg-brand-orange-dk transition-colors whitespace-nowrap"
          >
            Get a Freight Quote
          </a>
          <a
            href={`tel:${config.contact.phone}`}
            class="inline-flex items-center justify-center border border-white/30 text-white px-7 py-3.5 rounded font-medium hover:bg-white/10 transition-colors whitespace-nowrap"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
