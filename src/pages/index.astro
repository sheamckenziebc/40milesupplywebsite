---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={config.site.title} description={config.site.description}>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center px-4 py-2 bg-amber-500/20 border border-amber-500/30 rounded-full text-amber-300 text-sm font-medium mb-6">
            Mayo-based freight service
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
            Dependable Weekend Freight Between Mayo and Whitehorse
          </h1>
          <p class="text-lg md:text-xl text-blue-100 mb-8 max-w-xl leading-relaxed">
            40 Mile Supply is a Mayo-based freight service built to keep supplies moving. We handle weekend freight runs, Whitehorse pickups, and practical delivery support for businesses, contractors, organizations, and local customers.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
            >
              Request Quote
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            {config.features.products && (
              <a
                href={`${base}services/`}
                class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
              >
                View Services
              </a>
            )}
          </div>
          <div class="flex items-center gap-6 mt-8 pt-8 border-t border-white/10">
            <div class="text-center">
              <div class="text-2xl font-bold text-white">Mayo-Based</div>
              <div class="text-xs text-blue-200 uppercase tracking-wide">Local focus</div>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">Weekend Runs</div>
              <div class="text-xs text-blue-200 uppercase tracking-wide">Scheduled service</div>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">Whitehorse Pickups</div>
              <div class="text-xs text-blue-200 uppercase tracking-wide">Supplier coordination</div>
            </div>
            <div class="w-px h-10 bg-white/20"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-white">Practical Freight</div>
              <div class="text-xs text-blue-200 uppercase tracking-wide">Built for the route</div>
            </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <img
            src={`${base}assets/hero-image.svg`}
            alt="40 Mile Supply freight service — Mayo to Whitehorse"
            class="w-full h-auto max-h-[500px] object-contain drop-shadow-2xl"
            fetchpriority="high"
            width="500"
            height="500"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Trust Bar / Differentiators -->
  <section class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center stagger-children">
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-[#1F4A46] mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Mayo-Based</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-[#1F4A46] mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Weekend Runs</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-[#1F4A46] mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          <span class="text-sm font-semibold text-gray-900">Whitehorse Pickups</span>
        </div>
        <div class="animate-on-scroll flex flex-col items-center">
          <svg class="w-8 h-8 text-[#1F4A46] mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-sm font-semibold text-gray-900">Practical Freight</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why 40 Mile Supply
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          A practical local freight company focused on the Mayo–Whitehorse route.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-[#1F4A46] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Mayo-Based, Route-Focused</h3>
          <p class="text-gray-600 leading-relaxed">
            We are built around the Mayo–Whitehorse corridor, with local knowledge and a clear service focus instead of one-size-fits-all logistics.
          </p>
        </div>

        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-[#1F4A46] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Reliable Weekend Runs</h3>
          <p class="text-gray-600 leading-relaxed">
            Weekend scheduling helps businesses and projects plan restocks, pickups, and deliveries without guesswork.
          </p>
        </div>

        <div class="animate-on-scroll card-hover relative p-8 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="card-icon w-14 h-14 bg-[#1F4A46] rounded-xl flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Practical Freight Support</h3>
          <p class="text-gray-600 leading-relaxed">
            From store orders and supplies to job-site materials and recurring runs, we offer straightforward coordination and responsive service.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <span class="text-[#1F4A46] font-semibold text-sm uppercase tracking-wider">About 40 Mile Supply</span>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-6">
            Built for the Mayo–Whitehorse Link
          </h2>
          <p class="text-lg text-gray-600 mb-6">
            40 Mile Supply is launching with one clear goal: make it easier to move goods between Mayo and Whitehorse on a dependable schedule.
          </p>
          <p class="text-lg text-gray-600 mb-8">
            We focus on one route and do it well — weekend freight runs, Whitehorse pickups, and practical delivery support for businesses, contractors, organizations, and local customers.
          </p>
          <a
            href={`${base}about/`}
            class="inline-flex items-center text-[#1F4A46] font-semibold hover:opacity-90 transition-colors group"
          >
            Learn more about us
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="relative">
          <img
            src={`${base}assets/about-story.svg`}
            alt="40 Mile Supply — Mayo to Whitehorse freight"
            class="rounded-2xl shadow-lg w-full h-80 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Serve -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Who We Serve
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Built for businesses, contractors, organizations, and local customers who need practical freight on the Mayo–Whitehorse route.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        <div class="animate-on-scroll flex items-start gap-4 p-6 bg-gray-50 rounded-xl border border-gray-100">
          <svg class="w-8 h-8 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Local businesses and retailers</h3>
            <p class="text-sm text-gray-600">Restock runs, supplier pickups, and routine supply delivery.</p>
          </div>
        </div>
        <div class="animate-on-scroll flex items-start gap-4 p-6 bg-gray-50 rounded-xl border border-gray-100">
          <svg class="w-8 h-8 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Contractors and project crews</h3>
            <p class="text-sm text-gray-600">Tools, materials, and project freight for the Silver Trail and Mayo area.</p>
          </div>
        </div>
        <div class="animate-on-scroll flex items-start gap-4 p-6 bg-gray-50 rounded-xl border border-gray-100">
          <svg class="w-8 h-8 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Community organizations and offices</h3>
            <p class="text-sm text-gray-600">Supplies and materials moved on a schedule that works.</p>
          </div>
        </div>
        <div class="animate-on-scroll flex items-start gap-4 p-6 bg-gray-50 rounded-xl border border-gray-100">
          <svg class="w-8 h-8 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Households and small operators</h3>
            <p class="text-sm text-gray-600">Practical freight support when you need something moved.</p>
          </div>
        </div>
        <div class="animate-on-scroll flex items-start gap-4 p-6 bg-gray-50 rounded-xl border border-gray-100 sm:col-span-2 lg:col-span-1">
          <svg class="w-8 h-8 text-[#1F4A46] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l4-4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Suppliers needing reliable movement</h3>
            <p class="text-sm text-gray-600">Northbound and southbound freight on the Mayo–Whitehorse route.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works (mini) -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10 animate-on-scroll">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 stagger-children">
        <div class="animate-on-scroll text-center">
          <div class="w-12 h-12 bg-[#1F4A46] rounded-full flex items-center justify-center mx-auto mb-3 text-white font-bold">1</div>
          <p class="text-sm font-semibold text-gray-900">Request a Quote</p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-12 h-12 bg-[#1F4A46] rounded-full flex items-center justify-center mx-auto mb-3 text-white font-bold">2</div>
          <p class="text-sm font-semibold text-gray-900">Confirm Pickup Details</p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-12 h-12 bg-[#1F4A46] rounded-full flex items-center justify-center mx-auto mb-3 text-white font-bold">3</div>
          <p class="text-sm font-semibold text-gray-900">Weekend Freight Run</p>
        </div>
        <div class="animate-on-scroll text-center">
          <div class="w-12 h-12 bg-[#1F4A46] rounded-full flex items-center justify-center mx-auto mb-3 text-white font-bold">4</div>
          <p class="text-sm font-semibold text-gray-900">Delivery / Drop-Off</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative py-20 bg-gradient-to-br from-[#1F4A46] to-slate-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Need freight moved between Mayo and Whitehorse?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Get in touch for a quote, pickup coordination, or to ask about upcoming weekend runs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
        >
          Get a Freight Quote
        </a>
        <a
          href={`tel:${config.contact.phone}`}
          class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-white/10 transition-all"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Contact 40 Mile Supply
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
