---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const productsPath = join(process.cwd(), 'src/data/products.yaml');
const products = yaml.load(readFileSync(productsPath, 'utf8')) as Array<{ id: string; name: string; description: string; price: string; image: string; category: string; featured: boolean; features: string[]; specifications?: Record<string, string> }>;
const base = import.meta.env.BASE_URL;

const processSteps = [
  { step: "01", title: "Request a Quote", description: "Tell us what you need to move, when, and where. We'll respond with clear next steps and a quote." },
  { step: "02", title: "Confirm Pickup Details", description: "We confirm pickup location, contact, and any special instructions so the run goes smoothly." },
  { step: "03", title: "Weekend Freight Run", description: "Your freight moves on our scheduled weekend run between Mayo and Whitehorse." },
  { step: "04", title: "Delivery / Drop-Off", description: "We deliver to your chosen location. You get your goods; we keep the process simple." }
];

const serviceItems = products.map(p => {
  const item: Record<string, any> = { name: p.name, description: p.description };
  item["@type"] = "Service";
  return item;
});
const serviceProvider: Record<string, any> = { name: config.site.title, url: config.site.url };
serviceProvider["@type"] = "LocalBusiness";
const serviceObj: Record<string, any> = { provider: serviceProvider, hasOfferCatalog: { itemListElement: serviceItems } };
serviceObj["@context"] = "https://schema.org";
serviceObj["@type"] = "Service";
serviceObj.hasOfferCatalog["@type"] = "OfferCatalog";
const serviceJsonLd = JSON.stringify(serviceObj);
---

<BaseLayout title={`Services | ${config.site.title}`} description="Dependable freight services for the Mayo–Whitehorse route: weekend runs, Whitehorse pickups, business restock, contractor freight, and custom coordination.">
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 py-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-amber-400 font-semibold text-sm uppercase tracking-wider">What We Do</span>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mt-2 mb-6">
        Dependable Freight Services for the Mayo–Whitehorse Route
      </h1>
      <p class="text-xl text-blue-100 max-w-3xl mx-auto leading-relaxed">
        Weekend freight runs, Whitehorse pickups, business restock, and project freight — all with clear communication and practical local service.
      </p>
    </div>
  </section>

  <!-- Wave Divider -->
  <div class="bg-gradient-to-br from-slate-900 via-[#1F4A46] to-slate-800 -mb-1">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 24C480 20 600 28 720 32C840 36 960 36 1080 32C1200 28 1320 20 1380 16L1440 12V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="white"/>
    </svg>
  </div>

  <!-- Services Grid (from products.yaml, displayed as services) -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
        {products.map((service) => (
          <div class="animate-on-scroll group bg-gray-50 rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 bg-[#1F4A46] rounded-xl flex items-center justify-center mb-6 group-hover:bg-amber-500 transition-colors">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{service.name}</h3>
            <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
            {service.features && service.features.length > 0 && (
              <ul class="text-sm text-gray-600 space-y-1 mb-4">
                {service.features.slice(0, 3).map((f: string) => (
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-[#1F4A46] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
            )}
            <div class="flex items-center justify-between pt-4 border-t border-gray-200">
              <span class="text-sm font-semibold text-[#1F4A46]">{service.price}</span>
              <a href={`${base}contact/`} class="text-sm font-semibold text-gray-500 hover:text-[#1F4A46] transition-colors inline-flex items-center">
                Request Quote
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-on-scroll">
        <span class="text-[#1F4A46] font-semibold text-sm uppercase tracking-wider">How It Works</span>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2 mb-4">Our Process</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          A simple, four-step process from quote to delivery.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
        {processSteps.map((item) => (
          <div class="animate-on-scroll relative text-center">
            <div class="w-16 h-16 bg-[#1F4A46] rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-xl font-extrabold text-white">{item.step}</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 bg-gradient-to-br from-[#1F4A46] to-slate-800 overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.2&quot; fill-rule=&quot;evenodd&quot;%3E%3Cpath d=&quot;M0 40L40 0H20L0 20M40 40V20L20 40&quot;/%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Ready to get a quote?
      </h2>
      <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
        Tell us what you need to move and we'll get back to you with clear next steps.
      </p>
      <a
        href={`${base}contact/`}
        class="inline-flex items-center justify-center bg-amber-500 text-slate-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-amber-400 transition-all shadow-lg"
      >
        Request a Freight Quote
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={serviceJsonLd} />
  <Footer slot="footer" />
</BaseLayout>
