---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';

const configPath = join(process.cwd(), 'config.yaml');
const config = yaml.load(readFileSync(configPath, 'utf8'));
const productsPath = join(process.cwd(), 'src/data/products.yaml');
const products = yaml.load(readFileSync(productsPath, 'utf8')) as Array<{
  id: string; name: string; tagline: string; description: string;
  price: string; featured: boolean; features: string[];
  markets?: string[]; routes?: string[];
}>;
const base = import.meta.env.BASE_URL;

const brokerage = products.find(p => p.id === 'brokerage')!;
const hotshot   = products.find(p => p.id === 'hotshot')!;
const freight   = products.find(p => p.id === 'freight')!;

const advantages = [
  {
    title: "Automated Market Coverage",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
    body: "We use automated technology and continuous listing monitoring to scan southern markets efficiently, so promising inventory does not get missed. In competitive markets, good units often sell quickly. Our process helps clients see opportunities early — before the best listings are already gone."
  },
  {
    title: "Trusted Vendor Network",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    body: "We bring access to a trusted network of vendors, dealers, and industry contacts. That means better reach into quality inventory, better background on sellers, and a stronger ability to identify equipment that is worth serious attention. Not every listing tells the full story — we help clients separate real opportunities from wasted time."
  },
  {
    title: "Independent Inspections",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    body: "Before final decisions are made, we can coordinate independent inspections on equipment so buyers have an objective assessment of condition, fit, and risk. That extra step helps reduce surprises and gives clients more confidence before committing money and arranging transport north."
  }
];

const valuePoints = [
  "Automated listing coverage so no opportunity is missed",
  "Access to a trusted network of vendors and dealers",
  "Better screening of listings, sellers, and equipment quality",
  "Independent inspections before final purchase decisions",
  "Less time chasing weak or misleading listings",
  "Practical sourcing with Yukon use and value in mind",
  "Support from discovery through to landed asset",
];
---

<BaseLayout
  title={`Services | ${config.site.title}`}
  description="40 Mile Supply helps Yukon buyers source equipment with better market coverage, less risk, and less wasted time. Hot Shot and Regular Freight on the Mayo–Whitehorse and Dawson City–Mayo corridors."
>
  <Header slot="header" />

  <!-- Page header band -->
  <div class="bg-brand-navy border-b border-brand-teal-mid/50 py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="cyan-rule"></span>
      <h1 class="font-display font-700 text-3xl md:text-4xl text-white mb-2">Our Services</h1>
      <p class="text-gray-400 max-w-xl">Equipment brokerage with real market reach, urgent hot shot runs, and dependable scheduled freight — operated from Mayo, Yukon.</p>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- BROKERAGE                                           -->
  <!-- ═══════════════════════════════════════════════════ -->

  <!-- Flagship intro card -->
  <section class="pt-16 pb-0 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="animate-on-scroll border-2 border-brand-cyan/60 rounded-md overflow-hidden">
        <div class="bg-brand-cyan px-6 py-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-navy flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span class="text-brand-navy text-xs font-bold uppercase tracking-widest">Flagship Service</span>
        </div>

        <div class="bg-brand-navy p-8 md:p-10">
          <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
            <div class="lg:col-span-3">
              <div class="flex items-center gap-4 mb-5">
                <div class="w-12 h-12 bg-brand-teal rounded flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </div>
                <div>
                  <h2 class="font-display font-700 text-white text-2xl md:text-3xl leading-tight">{brokerage.name}</h2>
                  <p class="text-brand-cyan text-sm mt-0.5">{brokerage.tagline}</p>
                </div>
              </div>

              <p class="text-gray-300 leading-relaxed mb-5">
                Buying trucks, trailers, tools, and equipment from outside the Yukon is not just about finding a listing. It is about reducing risk, saving time, and making sure the right unit is worth bringing north in the first place. That is where we add value.
              </p>
              <p class="text-gray-400 leading-relaxed mb-6">
                Our service is built around three core advantages: market coverage, trusted sourcing, and disciplined decision-making — coordinating the full process from listing discovery through to landed asset.
              </p>

              <!-- Sourcing markets -->
              <div class="mb-8">
                <p class="text-xs text-gray-500 uppercase tracking-widest mb-3">Sourcing Markets</p>
                <div class="flex flex-wrap gap-2">
                  {brokerage.markets?.map(market => (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-teal/40 border border-brand-teal-mid rounded text-xs text-gray-300">
                      <svg class="w-3 h-3 text-brand-cyan flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      {market}
                    </span>
                  ))}
                </div>
              </div>

              <a
                href={`${base}contact/`}
                class="inline-flex items-center justify-center bg-brand-orange text-white px-7 py-3 rounded font-semibold hover:bg-brand-orange-dk transition-colors"
              >
                Request a Brokerage Quote
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>

            <div class="lg:col-span-2">
              <div class="bg-brand-teal/30 border border-brand-teal-mid rounded-md p-6 h-full">
                <h3 class="font-display font-600 text-white text-base mb-5 uppercase tracking-wide">What We Bring</h3>
                <ul class="space-y-3">
                  {valuePoints.map(point => (
                    <li class="flex items-start gap-3">
                      <svg class="w-4 h-4 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-gray-300 text-sm leading-relaxed">{point}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three core advantages -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 animate-on-scroll">
        <span class="cyan-rule"></span>
        <h2 class="text-2xl md:text-3xl font-display font-700 text-gray-900 mb-2">How We Source Smarter</h2>
        <p class="text-gray-500 max-w-xl">Three things that make the difference between finding the right unit and wasting time on the wrong ones.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
        {advantages.map(adv => (
          <div class="animate-on-scroll bg-brand-navy border border-brand-teal-mid rounded-md p-7">
            <div class="w-11 h-11 bg-brand-teal rounded flex items-center justify-center mb-5">
              <svg class="w-5 h-5 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={adv.icon} />
              </svg>
            </div>
            <h3 class="font-display font-700 text-white text-lg mb-3">{adv.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed">{adv.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing value statement -->
  <section class="py-14 bg-brand-surface border-y border-gray-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 animate-on-scroll">
      <blockquote class="text-center">
        <p class="text-xl md:text-2xl font-display font-700 text-gray-900 leading-snug mb-4">
          "Our value is not just finding equipment."
        </p>
        <p class="text-gray-600 leading-relaxed mb-2">
          We bring a northern buyer's perspective to southern markets. We are not simply looking for what is available — we are looking for equipment, trucks, trailers, and accessories that are practical, durable, and worthwhile for clients in the Yukon.
        </p>
        <p class="text-gray-500 leading-relaxed">
          A good equipment brokerage service should pay for itself in better buying decisions, fewer mistakes, and less wasted effort. That is what 40 Mile Supply is built to do.
        </p>
      </blockquote>
    </div>
  </section>

  <!-- Separator -->
  <div class="h-px bg-gradient-to-r from-transparent via-brand-cyan/20 to-transparent"></div>

  <!-- ═══════════════════════════════════════════════════ -->
  <!-- FREIGHT SERVICES                                    -->
  <!-- ═══════════════════════════════════════════════════ -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10 animate-on-scroll">
        <span class="cyan-rule"></span>
        <h2 class="text-2xl md:text-3xl font-display font-700 text-gray-900 mb-2">Freight Services</h2>
        <p class="text-gray-500">Scheduled runs and urgent delivery across the region.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
        {[
          {
            service: hotshot,
            icon: "M13 10V3L4 14h7v7l9-11h-7z",
            note: "Contact us to confirm availability. Pricing depends on load, route, and timing."
          },
          {
            service: freight,
            icon: "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0",
            note: "Regular schedule with custom arrangements available. Quote-based pricing."
          }
        ].map(({ service, icon, note }) => (
          <div class="animate-on-scroll card-hover bg-brand-navy border border-brand-teal-mid rounded-md p-7 flex flex-col">
            <div class="card-icon w-11 h-11 bg-brand-teal rounded flex items-center justify-center mb-4 flex-shrink-0">
              <svg class="w-5 h-5 text-brand-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={icon} />
              </svg>
            </div>
            <h3 class="font-display font-700 text-white text-xl mb-1">{service.name}</h3>
            <p class="text-brand-cyan text-xs mb-4">{service.tagline}</p>
            {service.routes && (
              <div class="flex flex-wrap gap-1.5 mb-5">
                {service.routes.map(route => (
                  <span class="px-2.5 py-1 bg-brand-teal/40 border border-brand-teal-mid rounded text-xs text-gray-300">{route}</span>
                ))}
              </div>
            )}
            <p class="text-gray-400 text-sm leading-relaxed mb-5">{service.description}</p>
            <ul class="space-y-2.5 flex-1">
              {service.features.map(f => (
                <li class="flex items-start gap-2.5 text-sm text-gray-400">
                  <svg class="w-4 h-4 text-brand-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <div class="mt-5 pt-5 border-t border-brand-teal-mid/50">
              <p class="text-xs text-gray-500 leading-relaxed mb-4">{note}</p>
              <a
                href={`${base}contact/`}
                class="inline-flex items-center text-xs font-semibold text-brand-cyan hover:text-white transition-colors uppercase tracking-wider"
              >
                {service.price === 'Contact for Availability' ? 'Check Availability' : 'Request Quote'}
                <svg class="w-3.5 h-3.5 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="py-16 bg-brand-navy border-t border-brand-teal-mid/40">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
      <span class="cyan-rule mx-auto mb-4"></span>
      <h2 class="font-display font-700 text-white text-2xl md:text-3xl mb-3">Not sure which service fits?</h2>
      <p class="text-gray-400 mb-8 max-w-md mx-auto">Tell us what you need and where it needs to go — we will find the right approach. No obligation.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={`${base}contact/`}
          class="inline-flex items-center justify-center bg-brand-orange text-white px-7 py-3.5 rounded font-semibold hover:bg-brand-orange-dk transition-colors"
        >
          Get in Touch
        </a>
        <a
          href={`tel:${config.contact.phone}`}
          class="inline-flex items-center justify-center border border-brand-teal-mid text-gray-300 px-7 py-3.5 rounded font-medium hover:border-brand-cyan/40 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {config.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
